{
  "name": "md2pdf",
  "version": "1.0.0",
  "description": "Markdown editor with live preview, Mermaid diagrams and PDF export",
  "main": "dist/main/main.js",
  "scripts": {
    "build:main": "tsc --project tsconfig.main.json",
    "build:renderer": "esbuild src/renderer/renderer.ts --bundle --outfile=dist/renderer/renderer.js --platform=browser --format=iife --target=chrome120 --loader:.ts=ts",
    "build": "npm run build:main && npm run build:renderer",
    "start": "npm run build && electron . --no-sandbox",
    "dev": "npm run build && electron . --no-sandbox",
    "pack": "npm run build && electron-builder --linux AppImage"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@codemirror/commands": "^6.3.0",
    "@codemirror/lang-markdown": "^6.2.0",
    "@codemirror/language-data": "^6.3.0",
    "@codemirror/state": "^6.4.0",
    "@codemirror/view": "^6.23.0",
    "codemirror": "^6.0.1",
    "markdown-it": "^14.0.0",
    "mermaid": "^10.7.0"
  }
}
